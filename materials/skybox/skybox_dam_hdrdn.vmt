"UnlitGeneric" 
{ 
// Original shader: BaseTexture 
"$basetexture" "skybox/skybox_damdn" 
// stops error: "Can't load skybox file skybox/(skyboxname) to build the default cubemap!" 
"$hdrbasetexture" "skybox/skybox_dam_hdrdn" 
"$nofog" "1" 
"$ignorez" "1" 
}