"Unlittwotexture"
{
	"$basetexture" "exor/warmup03"
	"$texture2" "exor/warmup04"
	"$translucent" "1"
	"$additive" 1
	"$nodecal" 1
	
	"$selfillum" "1"
	"$selfillumtint" "[7 7 7]"
	
	"$selfillummask" 	"exor/warmup_illumination"

	"Proxies"
	{


	"Sine"
		{
			// This is the data for the sine proxy
			// Notice there is no '$' on the proxy variables
			"resultVar"	"$alpha"
			"sineperiod"	0.3
			"sinemin"	0
			"sinemax"	1
		}	
	
	
	"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .05
			"texturescrollangle" -25
		}
		"TextureScroll"
		{
			"texturescrollvar" "$texture2transform"
			"texturescrollrate" .05
			"texturescrollangle" 40
		}
		
		
	}
}